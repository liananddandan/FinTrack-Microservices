{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "OpenApiServices": {
    "Identity": "http://identity-service:8080",
    "Transaction": "http://transaction-service:8080",
    "AuditLog": "http://auditlog-service:8080"
  },
  "ConnectionStrings": {
    "Redis": "localhost:6379"
  },
  "Authentication": {
    "AuthWhiteList": [
      "/api/account/confirm-email",
      "/api/account/login",
      "/api/tenant/register",
      "/api/account/register",
      "/api/tenant/context",
      "/api/dev/seed",
      "/api/swagger",
      "/api/swagger/index.html",
      "/api/swagger/scalar.js",
      "/api/swagger/scalar.aspnetcore.js",
      "/openapi/index.html.json",
      "/favicon.ico",
      "/api/swagger/favicon.svg",
      "/openapi/identity.json",
      "/openapi/transaction.json",
      "/openapi/auditlog.json",
      "/openapi/all.json"
    ]
  },
  "JwtSettings": {
    "Secret": "very-strong-secret-key-for-hmac256",
    "Issuer": "FinTrack",
    "Audience": "FinTrackAudience",
    "AccessTokenExpirationMinutes": 60,
    "FirstLoginChangePasswordExpirationMinutes": 10,
    "RefreshTokenExpirationDays": 7,
    "InvitationTokenExpirationDays": 7
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "identityOpenApi": {
        "ClusterId": "identityCluster",
        "Match": {
          "Path": "/openapi/identity.json"
        },
        "Transforms": [
          {
            "PathPattern": "/openapi/v1.json"
          }
        ]
      },
      "transactionOpenApi": {
        "ClusterId": "transactionCluster",
        "Match": {
          "Path": "/openapi/transaction.json"
        },
        "Transforms": [
          {
            "PathPattern": "/openapi/v1.json"
          }
        ]
      },
      "auditlogOpenApi": {
        "ClusterId": "auditlogCluster",
        "Match": {
          "Path": "/openapi/auditlog.json"
        },
        "Transforms": [
          {
            "PathPattern": "/openapi/v1.json"
          }
        ]
      },
      "account": {
        "ClusterId": "identityCluster",
        "Match": {
          "Path": "/api/account/{**catch-all}"
        },
        "Transforms": [
          {
            "RequestHeaderOriginalHost": "true"
          }
        ]
      },
      "tenant": {
        "ClusterId": "identityCluster",
        "Match": {
          "Path": "/api/tenant/{**catch-all}"
        },
        "Transforms": [
          {
            "RequestHeaderOriginalHost": "true"
          }
        ]
      },
      "transaction": {
        "ClusterId": "transactionCluster",
        "Match": {
          "Path": "/api/transactions/{**catch-all}"
        }
      },
      "auditlog": {
        "ClusterId": "auditlogCluster",
        "Match": {
          "Path": "/api/audit-logs/{**catch-all}"
        }
      },
      "productCategories": {
        "ClusterId": "transactionCluster",
        "Match": {
          "Path": "/api/product-categories/{**catch-all}"
        }
      },
      "products": {
        "ClusterId": "transactionCluster",
        "Match": {
          "Path": "/api/products/{**catch-all}"
        }
      },
      "orders": {
        "ClusterId": "transactionCluster",
        "Match": {
          "Path": "/api/orders/{**catch-all}"
        }
      },
      "platforms": {
        "ClusterId": "platformCluster",
        "Match": {
          "Path": "/api/platform/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "identityCluster": {
        "Destinations": {
          "identity": {
            "Address": "http://localhost:5100/"
          }
        }
      },
      "transactionCluster": {
        "Destinations": {
          "transaction": {
            "Address": "http://localhost:5133"
          }
        }
      },
      "auditlogCluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5107/"
          }
        }
      },
      "platformCluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5041/"
          }
        }
      }
    }
  }
}
